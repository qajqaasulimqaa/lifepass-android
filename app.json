{
  "expo": {
    "name": "LifePass",
    "slug": "lifepass-iceland",
    "version": "1.0.0",
    "scheme": "lifepass",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5EF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "is.lifepass.ios",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "LifePass uses your location to suggest wellness venues near you.",
        "NSSpeechRecognitionUsageDescription": "Allow LifePass to use speech recognition so you can speak to your wellness coach.",
        "NSMicrophoneUsageDescription": "Allow LifePass to use the microphone for voice input."
      }
    },
    "android": {
      "package": "is.lifepass.android",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "lifepass.is",
              "pathPrefix": "/scan"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0A1E3A",
          "sounds": []
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow LifePass to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow LifePass to use speech recognition so you can speak to your wellness coach."
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "a5813f67-0cd8-439f-a597-9681dcbc0368"
      }
    },
    "owner": "lifepass"
  }
}
